# OpenAI
OPENAI_API_KEY=
# Optional answer model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Neo4j graph store
# For Neo4j Aura, copy these from the credentials file you downloaded when
# creating the instance (URI uses the neo4j+s:// scheme).
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
# Target database name (Aura Free uses the same value as the username/instance id)
NEO4J_DB_NAME=
